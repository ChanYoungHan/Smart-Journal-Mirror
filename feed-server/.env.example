# MCP 도구가 쓰기 API를 호출할 베이스 URL (같은 프로세스)
MIRROR_WEB_BASE=http://127.0.0.1:8090
# 상태 영속 파일
MIRROR_DATA_FILE=/app/data/state.json
# iframe 폴링 주기(ms)
MIRROR_POLL_MS=60000
# 메시지 회전 주기(ms)
MIRROR_ROTATE_MS=12000

# ── Claude 커넥터(OAuth 프록시) 연동용 ──
# /mcp 업스트림 보호 토큰 (설정 시 mirror-feed 가 Bearer 검사). 프록시와 동일 값 사용.
MIRROR_MCP_TOKEN=
# OAuth 프록시(mirror-feed-mcp-oauth) 공개 HTTPS 주소
MIRROR_MCP_PUBLIC_URL=https://mirror-mcp.example.com
# 프록시 단일 사용자 로그인 비번 / 토큰 서명 시크릿
MIRROR_MCP_ADMIN_PW=
MIRROR_MCP_TOKEN_SECRET=

# (선택) MCP DNS 리바인딩 보호 허용 호스트/오리진. 기본값이 mirror-feed/localhost 포함.
# 다른 업스트림 호스트명으로 프록시하면 추가. "host:*" 는 모든 포트 허용.
# MIRROR_MCP_ALLOWED_HOSTS=mirror-feed:*,localhost:*,127.0.0.1:*
# MIRROR_MCP_ALLOWED_ORIGINS=http://mirror-feed:*,http://localhost:*,http://127.0.0.1:*
