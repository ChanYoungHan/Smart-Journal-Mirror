# OAuth 2.1 프록시 설정 (Claude 커넥터 ↔ feed-server /mcp)
PORT=4001
PUBLIC_URL=https://mirror-mcp.example.com   # 공개 HTTPS 주소(도메인+리버스프록시)
MCP_UPSTREAM_URL=http://feed-server:8090/mcp/
MCP_BEARER_TOKEN=                            # 프록시→서버 내부 토큰 (openssl rand -hex 32)
ADMIN_PASSWORD=                              # 커넥터 로그인 비번
TOKEN_SECRET=                                # 토큰 서명 시크릿 (openssl rand -hex 32)
